# Server
PORT=3000
NODE_ENV=development

# Database (로컬/개발: 개별 변수 사용)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=table_order
DB_NAME_TEST=table_order_test

# Database (프로덕션: DATABASE_URL 이 있으면 우선 사용, SSL 자동 활성화 - Render Postgres)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# JWT
JWT_SECRET=your-secret-key-here
JWT_ADMIN_EXPIRES_IN=16h

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# 컨테이너 시작 시 시드 실행 여부 (true 일 때만 시드 적용, 시드는 기존 데이터 삭제)
# RUN_SEED=false
