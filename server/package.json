{
  "name": "table-order-server",
  "version": "1.0.0",
  "private": true,
  "description": "테이블오더 백엔드 서버 (Express + TypeScript)",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "migrate:latest": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "seed:run": "knex seed:run --knexfile knexfile.ts",
    "migrate:latest:prod": "knex migrate:latest --knexfile knexfile.ts --env production",
    "seed:run:prod": "knex seed:run --knexfile knexfile.ts --env production",
    "start:prod": "node dist/app.js"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "knex": "^3.1.0",
    "pg": "^8.11.0",
    "jsonwebtoken": "^9.0.0",
    "bcrypt": "^5.1.0",
    "zod": "^3.22.0",
    "dotenv": "^16.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.0",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^6.0.2"
  }
}
